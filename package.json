{
  "name": "opencode-ceo",
  "version": "0.1.0",
  "description": "Transform OpenCode into a deterministic software company operating system",
  "keywords": [
    "opencode",
    "plugin",
    "ai",
    "orchestration",
    "pipeline"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaur94/opencode-ceo.git"
  },
  "homepage": "https://github.com/vaur94/opencode-ceo#readme",
  "bugs": {
    "url": "https://github.com/vaur94/opencode-ceo/issues"
  },
  "author": "opencode-ceo contributors",
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.10"
  },
  "module": "./dist/index.js",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/",
    "README.md",
    "README.tr.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun && bun x tsc --declaration --emitDeclarationOnly --outDir dist",
    "typecheck": "bun x tsc --noEmit",
    "pack:check": "npm pack --dry-run",
    "ci:verify": "bun run build && bun run typecheck && bun test && bun run pack:check",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@opencode-ai/plugin": "latest",
    "@opencode-ai/sdk": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
